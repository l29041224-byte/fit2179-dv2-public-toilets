{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 850,
  "height": 360,
  "title": {
    "text": "How far are the busiest pedestrian areas from a toilet?",
    "subtitle": "Top 10 pedestrian sensors ranked by April 2026 activity"
  },
  "data": {
    "url": "data/top10_busy_sensor_access.csv"
  },
  "layer": [
    {
      "mark": {
        "type": "bar",
        "cornerRadiusEnd": 4
      },
      "encoding": {
        "x": {
          "field": "nearest_distance_m",
          "type": "quantitative",
          "title": "Distance to nearest public toilet (metres)"
        },
        "y": {
          "field": "sensor_description",
          "type": "nominal",
          "title": null,
          "sort": "-x"
        },
        "color": {
          "condition": {
            "test": "datum.nearest_distance_m >= 200",
            "value": "#e76f51"
          },
          "value": "#2a9d8f"
        },
        "tooltip": [
          {
            "field": "sensor_description",
            "title": "Sensor"
          },
          {
            "field": "total_pedestrians",
            "title": "April pedestrians",
            "format": ","
          },
          {
            "field": "nearest_distance_m",
            "title": "Nearest toilet distance (m)",
            "format": ".0f"
          },
          {
            "field": "nearest_toilet",
            "title": "Nearest toilet"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 5,
        "fontSize": 12
      },
      "encoding": {
        "x": {
          "field": "nearest_distance_m",
          "type": "quantitative"
        },
        "y": {
          "field": "sensor_description",
          "type": "nominal",
          "sort": "-x"
        },
        "text": {
          "field": "nearest_distance_m",
          "type": "quantitative",
          "format": ".0f"
        }
      }
    }
  ],
  "config": {
    "axis": {
      "labelFontSize": 12,
      "titleFontSize": 13
    },
    "view": {
      "stroke": "transparent"
    }
  }
}