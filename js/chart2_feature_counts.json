{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 650,
  "height": 300,
  "title": {
    "text": "What facilities do Melbourne public toilets provide?",
    "subtitle": "Count of toilets by facility feature"
  },
  "data": {
    "url": "data/feature_counts.csv"
  },
  "mark": {
    "type": "bar",
    "cornerRadiusEnd": 3
  },
  "encoding": {
    "x": {
      "field": "count",
      "type": "quantitative",
      "title": "Number of toilets"
    },
    "y": {
      "field": "feature",
      "type": "nominal",
      "title": null,
      "sort": "-x"
    },
    "color": {
      "field": "status",
      "type": "nominal",
      "title": "Available?",
      "scale": {
        "domain": [
          "yes",
          "no",
          "unknown"
        ],
        "range": [
          "#2a9d8f",
          "#e76f51",
          "#9ca3af"
        ]
      }
    },
    "tooltip": [
      {
        "field": "feature"
      },
      {
        "field": "status"
      },
      {
        "field": "count"
      }
    ]
  }
}