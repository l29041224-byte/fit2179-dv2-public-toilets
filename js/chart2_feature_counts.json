{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 820,
  "height": 320,
  "title": {
    "text": "What facilities are provided?",
    "subtitle": "Baby-change facilities are much less common than basic male and female facilities"
  },
  "data": {
    "url": "https://raw.githubusercontent.com/l29041224-byte/fit2179-dv2-public-toilets/refs/heads/main/data/feature_yes_counts.csv"
  },
  "layer": [
    {
      "mark": {
        "type": "bar",
        "cornerRadiusEnd": 5,
        "color": "#2a9d8f"
      },
      "encoding": {
        "y": {
          "field": "feature",
          "type": "nominal",
          "title": null,
          "sort": "-x"
        },
        "x": {
          "field": "yes_count",
          "type": "quantitative",
          "title": "Number of toilets"
        },
        "tooltip": [
          {
            "field": "feature",
            "title": "Facility"
          },
          {
            "field": "yes_count",
            "title": "Number of toilets"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 8,
        "fontSize": 13,
        "fontWeight": "bold",
        "color": "#1f2933"
      },
      "encoding": {
        "y": {
          "field": "feature",
          "type": "nominal",
          "sort": "-x"
        },
        "x": {
          "field": "yes_count",
          "type": "quantitative"
        },
        "text": {
          "field": "yes_count",
          "type": "quantitative"
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "feature": "Baby change",
            "yes_count": 5,
            "label": "Lowest availability"
          }
        ]
      },
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 48,
        "fontSize": 13,
        "fontWeight": "bold",
        "color": "#e76f51"
      },
      "encoding": {
        "y": {
          "field": "feature",
          "type": "nominal"
        },
        "x": {
          "field": "yes_count",
          "type": "quantitative"
        },
        "text": {
          "field": "label"
        }
      }
    }
  ],
  "config": {
    "axis": {
      "labelFontSize": 13,
      "titleFontSize": 13
    },
    "view": {
      "stroke": "transparent"
    }
  }
}