{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 720,
  "height": 260,
  "title": {
    "text": "How many toilets provide each facility?",
    "subtitle": "Number of toilets marked as yes in the dataset"
  },
  "data": {
    "url": "data/feature_yes_counts.csv"
  },
  "layer": [
    {
      "mark": {
        "type": "bar",
        "cornerRadiusEnd": 4,
        "color": "#2a9d8f"
      },
      "encoding": {
        "x": {
          "field": "yes_count",
          "type": "quantitative",
          "title": "Number of toilets",
          "scale": {
            "domain": [0, 74]
          }
        },
        "y": {
          "field": "feature",
          "type": "nominal",
          "title": null,
          "sort": "-x"
        },
        "tooltip": [
          {
            "field": "feature",
            "title": "Feature"
          },
          {
            "field": "yes_count",
            "title": "Yes count"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 5,
        "fontSize": 12
      },
      "encoding": {
        "x": {
          "field": "yes_count",
          "type": "quantitative"
        },
        "y": {
          "field": "feature",
          "type": "nominal",
          "sort": "-x"
        },
        "text": {
          "field": "yes_count",
          "type": "quantitative"
        }
      }
    }
  ],
  "config": {
    "axis": {
      "labelFontSize": 12,
      "titleFontSize": 12
    },
    "view": {
      "stroke": "transparent"
    }
  }
}