{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 880,
  "height": 500,
  "title": {
    "text": "Which locations should be checked first?",
    "subtitle": "Priority rises when pedestrian demand is high and the nearest toilet is farther away"
  },
  "data": {
    "url": "https://raw.githubusercontent.com/l29041224-byte/fit2179-dv2-public-toilets/refs/heads/main/data/priority_quadrant.csv"
  },
  "layer": [
    {
      "mark": {
        "type": "point",
        "filled": true,
        "opacity": 0.72,
        "stroke": "white",
        "strokeWidth": 1
      },
      "encoding": {
        "x": {
          "field": "total_pedestrians",
          "type": "quantitative",
          "title": "April pedestrian total",
          "axis": {
            "format": ".1s"
          }
        },
        "y": {
          "field": "nearest_distance_m",
          "type": "quantitative",
          "title": "Distance to nearest toilet (m)"
        },
        "size": {
          "field": "priority_score",
          "type": "quantitative",
          "title": "Priority score",
          "scale": {
            "range": [40, 900]
          }
        },
        "color": {
          "field": "priority_group",
          "type": "nominal",
          "title": "Priority group",
          "scale": {
            "domain": ["Lower priority", "Medium priority", "High priority"],
            "range": ["#2a9d8f", "#f4a261", "#e76f51"]
          }
        },
        "tooltip": [
          {
            "field": "sensor_description",
            "title": "Location"
          },
          {
            "field": "total_pedestrians",
            "title": "April pedestrians",
            "format": ","
          },
          {
            "field": "nearest_distance_m",
            "title": "Nearest toilet distance (m)",
            "format": ".0f"
          },
          {
            "field": "priority_group",
            "title": "Priority group"
          },
          {
            "field": "priority_score",
            "title": "Priority score",
            "format": ".1f"
          }
        ]
      }
    },
    {
      "data": {
        "values": [
          {
            "x": 600000
          }
        ]
      },
      "mark": {
        "type": "rule",
        "strokeDash": [6, 4],
        "color": "#6b7280",
        "strokeWidth": 1.5
      },
      "encoding": {
        "x": {
          "field": "x",
          "type": "quantitative"
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "y": 200
          }
        ]
      },
      "mark": {
        "type": "rule",
        "strokeDash": [6, 4],
        "color": "#6b7280",
        "strokeWidth": 1.5
      },
      "encoding": {
        "y": {
          "field": "y",
          "type": "quantitative"
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "total_pedestrians": 930000,
            "nearest_distance_m": 250,
            "label": "Priority zone"
          }
        ]
      },
      "mark": {
        "type": "text",
        "align": "center",
        "baseline": "middle",
        "fontSize": 18,
        "fontWeight": "bold",
        "color": "#e76f51"
      },
      "encoding": {
        "x": {
          "field": "total_pedestrians",
          "type": "quantitative"
        },
        "y": {
          "field": "nearest_distance_m",
          "type": "quantitative"
        },
        "text": {
          "field": "label"
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "total_pedestrians": 930000,
            "nearest_distance_m": 225,
            "label": "High demand + longer distance"
          }
        ]
      },
      "mark": {
        "type": "text",
        "align": "center",
        "baseline": "middle",
        "fontSize": 14,
        "fontWeight": "bold",
        "color": "#e76f51"
      },
      "encoding": {
        "x": {
          "field": "total_pedestrians",
          "type": "quantitative"
        },
        "y": {
          "field": "nearest_distance_m",
          "type": "quantitative"
        },
        "text": {
          "field": "label"
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "total_pedestrians": 600000,
            "nearest_distance_m": 530,
            "label": "High demand threshold"
          }
        ]
      },
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 8,
        "fontSize": 12,
        "color": "#6b7280"
      },
      "encoding": {
        "x": {
          "field": "total_pedestrians",
          "type": "quantitative"
        },
        "y": {
          "field": "nearest_distance_m",
          "type": "quantitative"
        },
        "text": {
          "field": "label"
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "total_pedestrians": 50000,
            "nearest_distance_m": 205,
            "label": "Longer distance threshold"
          }
        ]
      },
      "mark": {
        "type": "text",
        "align": "left",
        "dy": -8,
        "fontSize": 12,
        "color": "#6b7280"
      },
      "encoding": {
        "x": {
          "field": "total_pedestrians",
          "type": "quantitative"
        },
        "y": {
          "field": "nearest_distance_m",
          "type": "quantitative"
        },
        "text": {
          "field": "label"
        }
      }
    }
  ],
  "config": {
    "axis": {
      "labelFontSize": 13,
      "titleFontSize": 13
    },
    "legend": {
      "labelFontSize": 12,
      "titleFontSize": 12
    },
    "view": {
      "stroke": "transparent"
    }
  }
}