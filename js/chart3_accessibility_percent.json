{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 720,
  "height": 260,
  "title": {
    "text": "Where are the access gaps?",
    "subtitle": "Percentage split by yes, no and unknown for each feature"
  },
  "data": {
    "url": "data/feature_status_percent.csv"
  },
  "mark": {
    "type": "bar",
    "cornerRadiusEnd": 3
  },
  "encoding": {
    "x": {
      "field": "percent",
      "type": "quantitative",
      "title": "Share of records (%)",
      "stack": "zero",
      "scale": {
        "domain": [
          0,
          100
        ]
      }
    },
    "y": {
      "field": "feature",
      "type": "nominal",
      "title": null,
      "sort": [
        "Male facility",
        "Female facility",
        "Wheelchair accessible",
        "Baby change"
      ]
    },
    "color": {
      "field": "status",
      "type": "nominal",
      "title": "Status",
      "scale": {
        "domain": [
          "yes",
          "no",
          "unknown"
        ],
        "range": [
          "#2a9d8f",
          "#e76f51",
          "#9ca3af"
        ]
      }
    },
    "tooltip": [
      {
        "field": "feature"
      },
      {
        "field": "status"
      },
      {
        "field": "count",
        "title": "Count"
      },
      {
        "field": "percent",
        "title": "Percent"
      }
    ]
  },
  "config": {
    "axis": {
      "labelFontSize": 12,
      "titleFontSize": 12
    },
    "view": {
      "stroke": "transparent"
    }
  }
}