{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 850,
  "height": 280,
  "title": {
    "text": "Where are the access gaps?",
    "subtitle": "Baby-change facilities have the largest unavailable share"
  },
  "data": {
    "url": "data/feature_status_percent.csv"
  },
  "mark": {
    "type": "bar",
    "cornerRadiusEnd": 3
  },
  "encoding": {
    "x": {
      "field": "percent",
      "type": "quantitative",
      "title": "Share of records (%)",
      "stack": "zero",
      "scale": {
        "domain": [0, 100]
      }
    },
    "y": {
      "field": "feature",
      "type": "nominal",
      "title": null,
      "sort": [
        "Baby change",
        "Wheelchair accessible",
        "Female facility",
        "Male facility"
      ]
    },
    "color": {
      "field": "status",
      "type": "nominal",
      "title": "Status",
      "scale": {
        "domain": ["yes", "no", "unknown"],
        "range": ["#2a9d8f", "#e76f51", "#9ca3af"]
      },
      "legend": {
        "orient": "top",
        "direction": "horizontal",
        "labelExpr": "datum.label == 'yes' ? 'YES' : datum.label == 'no' ? 'NO' : 'UNKNOWN'"
      }
    },
    "tooltip": [
      {
        "field": "feature",
        "title": "Feature"
      },
      {
        "field": "status",
        "title": "Status"
      },
      {
        "field": "count",
        "title": "Count"
      },
      {
        "field": "percent",
        "title": "Percent",
        "format": ".1f"
      }
    ]
  },
  "config": {
    "axis": {
      "labelFontSize": 13,
      "titleFontSize": 13
    },
    "view": {
      "stroke": "transparent"
    },
    "legend": {
      "labelFontSize": 12,
      "titleFontSize": 12
    }
  }
}