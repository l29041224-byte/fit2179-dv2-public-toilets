{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 720,
  "height": 320,
  "title": {
    "text": "Population growth can reduce toilet access per person",
    "subtitle": "Using the current toilet count of 74 against ABS annual population estimates"
  },
  "data": {
    "url": "data/melbourne_population_context.csv"
  },
  "layer": [
    {
      "mark": {
        "type": "line",
        "point": {
          "filled": true,
          "size": 65
        },
        "strokeWidth": 3,
        "color": "#4c78a8"
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal",
          "title": "Year"
        },
        "y": {
          "field": "toilets_per_10000_people",
          "type": "quantitative",
          "title": "Current toilets per 10,000 people",
          "scale": {
            "zero": false
          }
        },
        "tooltip": [
          {
            "field": "year"
          },
          {
            "field": "population",
            "format": ",",
            "title": "Population"
          },
          {
            "field": "toilets_per_10000_people",
            "title": "Toilets per 10,000 people"
          }
        ]
      }
    }
  ],
  "config": {
    "axis": {
      "labelFontSize": 12,
      "titleFontSize": 12
    },
    "view": {
      "stroke": "transparent"
    }
  }
}