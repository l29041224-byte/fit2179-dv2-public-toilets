{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 900,
  "height": 380,
  "title": {
  "text": "Population growth can increase pressure on toilet access",
  "subtitle": "Current toilet count per 10,000 people, using ABS annual population estimates"
},
  "data": {
    "url": "https://raw.githubusercontent.com/l29041224-byte/fit2179-dv2-public-toilets/refs/heads/main/data/melbourne_population_context.csv"
  },
  "layer": [
    {
      "mark": {
        "type": "line",
        "point": {
          "filled": true,
          "size": 70
        },
        "strokeWidth": 3,
        "color": "#4c78a8"
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal",
          "title": "Year",
          "axis": {
            "labelAngle": 0
          }
        },
        "y": {
          "field": "toilets_per_10000_people",
          "type": "quantitative",
          "title": "Current toilets per 10,000 people",
          "scale": {
            "zero": false
          }
        },
        "tooltip": [
          {
            "field": "year",
            "title": "Year"
          },
          {
            "field": "population",
            "format": ",",
            "title": "Population"
          },
          {
            "field": "toilets_per_10000_people",
            "title": "Current toilets per 10,000 people"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 8,
        "fontSize": 12,
        "color": "#333"
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal"
        },
        "y": {
          "field": "toilets_per_10000_people",
          "type": "quantitative"
        },
        "text": {
          "field": "toilets_per_10000_people",
          "type": "quantitative",
          "format": ".2f"
        }
      }
    }
  ],
  "config": {
    "axis": {
      "labelFontSize": 13,
      "titleFontSize": 13
    },
    "view": {
      "stroke": "transparent"
    }
  }
}