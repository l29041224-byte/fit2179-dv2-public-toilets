{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 760,
  "height": 560,
  "title": {
    "text": "Where are Melbourne's public toilets?",
    "subtitle": "Each point is a public toilet; colour shows wheelchair accessibility"
  },
  "projection": {
    "type": "mercator",
    "center": [144.96, -37.81],
    "scale": 70000
  },
  "layer": [
    {
      "data": {
        "url": "data/melbourne_boundary.geojson",
        "format": {
          "type": "json",
          "property": "features"
        }
      },
      "mark": {
        "type": "geoshape",
        "fill": "#f1f3f5",
        "stroke": "#adb5bd",
        "strokeWidth": 1.2
      }
    },
    {
      "data": {
        "url": "data/public-toilets.geojson",
        "format": {
          "type": "json",
          "property": "features"
        }
      },
      "mark": {
        "type": "circle",
        "size": 95,
        "opacity": 0.85,
        "stroke": "white",
        "strokeWidth": 0.8
      },
      "encoding": {
        "longitude": {
          "field": "geometry.coordinates[0]",
          "type": "quantitative"
        },
        "latitude": {
          "field": "geometry.coordinates[1]",
          "type": "quantitative"
        },
        "color": {
          "field": "properties.wheelchair",
          "type": "nominal",
          "title": "Wheelchair accessible",
          "scale": {
            "domain": ["yes", "no", "U"],
            "range": ["#2a9d8f", "#e76f51", "#adb5bd"]
          },
          "legend": {
            "labelExpr": "datum.label == 'yes' ? 'YES' : datum.label == 'no' ? 'NO' : 'UNKNOWN'"
          }
        },
        "tooltip": [
          {
            "field": "properties.name",
            "title": "Toilet name"
          },
          {
            "field": "properties.wheelchair",
            "title": "Wheelchair accessible"
          },
          {
            "field": "properties.baby_facil",
            "title": "Baby change"
          }
        ]
      }
    }
  ],
  "config": {
    "view": {
      "stroke": "transparent"
    },
    "legend": {
      "labelFontSize": 12,
      "titleFontSize": 12
    }
  }
}