{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 800,
  "height": 520,
  "title": {
    "text": "Where are Melbourne\u2019s public toilets?",
    "subtitle": "Each point is a public toilet; colour shows wheelchair accessibility"
  },
  "data": {
    "url": "data/public-toilets.geojson",
    "format": {
      "type": "json",
      "property": "features"
    }
  },
  "projection": {
    "type": "mercator",
    "center": [
      144.956,
      -37.809
    ],
    "scale": 260000
  },
  "mark": {
    "type": "circle",
    "size": 120,
    "opacity": 0.9,
    "stroke": "white",
    "strokeWidth": 1
  },
  "encoding": {
    "longitude": {
      "field": "properties.lon",
      "type": "quantitative"
    },
    "latitude": {
      "field": "properties.lat",
      "type": "quantitative"
    },
    "color": {
      "field": "properties.wheelchair",
      "type": "nominal",
      "title": "Wheelchair accessible",
      "scale": {
        "domain": [
          "yes",
          "no",
          "U"
        ],
        "range": [
          "#2a9d8f",
          "#e76f51",
          "#9ca3af"
        ]
      },
      "legend": {
        "orient": "right"
      }
    },
    "tooltip": [
      {
        "field": "properties.name",
        "title": "Toilet"
      },
      {
        "field": "properties.wheelchair",
        "title": "Wheelchair accessible"
      },
      {
        "field": "properties.baby_facil",
        "title": "Baby change"
      },
      {
        "field": "properties.operator",
        "title": "Operator"
      }
    ]
  },
  "config": {
    "view": {
      "stroke": "transparent"
    }
  }
}